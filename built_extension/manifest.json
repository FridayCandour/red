{
  "manifest_version": 3,
  "name": "Premium Design Inspector",
  "version": "1.0.0",
  "description": "A world-class design inspector for professionals.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Toggle Inspector"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "assets/*", "src/panel.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
