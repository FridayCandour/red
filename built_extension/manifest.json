{
  "manifest_version": 3,
  "name": "Red Border Extension",
  "version": "2.0",
  "description": "An advanced inspector to highlight elements and view their properties.",
  "icons": {
    "128": "icon.svg"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "action": {},
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["assets/global.css"],
      "js": ["src/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "src/injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
